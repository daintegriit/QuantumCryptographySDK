FROM python:3.10-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl build-essential libssl-dev pkg-config && \
    rm -rf /var/lib/apt/lists/*

RUN curl https://sh.rustup.rs -sSf | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app

COPY backend/ .
COPY backend/crypto_core_rust ./crypto_core_rust

# ✅ requirements.txt is at repo root
COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt
RUN pip install fastapi uvicorn

EXPOSE 8008

CMD ["/bin/bash", "-c", "cd crypto_core_rust && cargo build && cd .. && uvicorn main:app --host 0.0.0.0 --port 8008 --reload"]